# 默认聊天供应商
ZAIWEN_API_KEY=sk-your-api-key-here
ZAIWEN_BASE_URL=xxxxxxx
ZAIWEN_MODEL=GLM-5
DEFAULT_CHAT_MODEL=GLM-5

# Claude 配置（可选）
CLAUDE_API_KEY=sk-your-claude-api-key-here
CLAUDE_BASE_URL=https://your-claude-compatible-base-url.com/v1
CLAUDE_MODEL=claude-opus-4-5-20251101

# 应用配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=postgres
DB_SYNCHRONIZE=true

# JWT 配置（必填）
# 请使用强随机字符串，至少 32 位，建议使用: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-key-at-least-32-characters-long

# Redis 配置
# 推荐本地 Docker 运行:
# docker run -d --name redis-dev -p 6379:6379 redis:latest
# 如果配置 REDIS_URL，则优先使用 REDIS_URL
# 例如:
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=
# 不使用 REDIS_URL 时，使用以下拆分配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
# 说明:
# - 验证码、发送频率限制等短期状态已迁移到 Redis
# - Redis 不可用时，认证相关接口将无法正常工作
# - 本地开发建议先通过 redis-cli ping 确认返回 PONG

# 附件签名 URL 配置
# FILE_URL_SIGN_SECRET 用于生成附件访问签名；未配置时会回退使用 JWT_SECRET
# 建议在生产环境单独配置，避免与认证密钥复用
FILE_URL_SIGN_SECRET=your-file-url-sign-secret
# FILE_URL_TTL_SECONDS 为签名 URL 的有效期，默认 86400 秒（24 小时）
# 建议策略：
# - 开发环境：86400（便于联调）
# - 生产环境：600 ~ 3600（10 分钟到 1 小时）
# - 如需长期展示历史附件，前端应在进入会话时刷新消息，获取新的签名 URL
FILE_URL_TTL_SECONDS=86400

# 超级管理员初始化配置（可选）
# 若不配置 ADMIN_INIT_PASSWORD，系统将生成随机密码并输出到日志
ADMIN_INIT_PASSWORD=your-secure-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# 阿里云邮件推送配置（可选）
# 如果不配置，邮件服务将被禁用，但不影响应用启动
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_REGION=cn-hangzhou
# 必须填写阿里云邮件推送控制台中已创建且已验证通过的发信地址
ALIYUN_FROM_EMAIL=noreply@yourdomain.com
ALIYUN_FROM_NAME=ERJCHAT
ALIYUN_REPLY_EMAIL=support@yourdomain.com
# 阿里云邮件请求超时配置（毫秒）
# 如果本地网络较慢，适当放大 read timeout
ALIYUN_DM_CONNECT_TIMEOUT_MS=5000
ALIYUN_DM_READ_TIMEOUT_MS=15000
ALIYUN_DM_MAX_ATTEMPTS=2
